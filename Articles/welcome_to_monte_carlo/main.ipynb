   "source": [
    "# Regress character on attractiveness to show that there is no correlation\n",
    "import statsmodels.api as sm\n",
    "\n",
    "# Add intercept\n",
    "X_with_const = sm.add_constant(berksons_df[['attractiveness']])\n",
    "\n",
    "# determine dependent variable (doesnt matter here)\n",
    "y = berksons_df['character']\n",
    "\n",
    "# fit OLS\n",
    "sm_model = sm.OLS(y, X_with_const).fit()\n",
    "\n",
    "# 3. Print the results (includes Coeff, P-values, and 95% Conf. Intervals)\n",
    "print(sm_model.summary())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "f5f6fe4d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Add a selection bias where the sum of attractiveness and character is >14\n",
    "berksons_df[\"bias\"] = (berksons_df['attractiveness'] + berksons_df['character']) > 14"
   ]
  },
