   "source": [
    "selected_group = berksons_df[berksons_df[\"bias\"] == True]\n",
    "\n",
    "X = sm.add_constant(selected_group['attractiveness'])\n",
    "y = selected_group['character']\n",
    "\n",
    "model = sm.OLS(y, X).fit()\n",
    "print(model.summary())"
   ]
